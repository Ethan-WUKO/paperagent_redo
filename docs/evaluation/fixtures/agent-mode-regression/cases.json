{
  "runtimeCases": [
    {
      "caseId": "runtime_followup_codename",
      "title": "Direct follow-up keeps short-term project codename",
      "history": [
        {
          "role": "user",
          "content": "For this sprint, my project codename is Orion."
        },
        {
          "role": "assistant",
          "content": "Understood. I will keep using Orion as the project codename in this conversation."
        }
      ],
      "userMessage": "What codename am I using for the project right now?",
      "expectedAnswerContains": [
        "Orion"
      ]
    },
    {
      "caseId": "runtime_followup_owner",
      "title": "Direct runtime can reuse earlier user facts",
      "history": [
        {
          "role": "user",
          "content": "The knowledge base owner for this workspace is Lin Mei."
        },
        {
          "role": "assistant",
          "content": "Noted. Lin Mei is the recorded owner for this workspace."
        }
      ],
      "userMessage": "Who is the knowledge base owner I mentioned earlier?",
      "expectedAnswerContains": [
        "Lin Mei"
      ]
    }
  ],
  "toolCases": [
    {
      "caseId": "tool_search_web_latest",
      "title": "Time-sensitive public question should trigger web search",
      "history": [],
      "userMessage": "Please check the latest radar benchmark update.",
      "allowedTools": [
        "search_web"
      ],
      "expectedToolName": "search_web",
      "expectedToolQuery": "latest radar benchmark update",
      "expectedAnswerContains": [
        "search_web",
        "RKB-2026"
      ]
    },
    {
      "caseId": "tool_search_knowledge_formal_name",
      "title": "Private project naming question should trigger knowledge search",
      "history": [],
      "userMessage": "Use the project notes and tell me the formal project name.",
      "allowedTools": [
        "search_knowledge"
      ],
      "expectedToolName": "search_knowledge",
      "expectedToolQuery": "formal project name",
      "expectedAnswerContains": [
        "search_knowledge",
        "Yanban ScholarAI"
      ]
    }
  ],
