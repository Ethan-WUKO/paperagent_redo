# Yanban Agent local development environment example
# Copy to .env locally if needed. Never commit real secrets.

# LLM providers
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODELS_URL=https://api.deepseek.com/models
DEEPSEEK_MODEL=deepseek-v4-flash
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-5.2
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Web search provider
# Cost-saving Tavily defaults: basic search is cheaper than advanced, no raw content/images/LLM answer.
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_MAX_RESULTS=8
WEB_SEARCH_CACHE_TTL=30m
WEB_SEARCH_FALLBACK_TO_DUCKDUCKGO=true
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_DEPTH=basic
TAVILY_AUTO_PARAMETERS=false
TAVILY_INCLUDE_ANSWER=false
TAVILY_INCLUDE_RAW_CONTENT=false
TAVILY_INCLUDE_IMAGES=false
TAVILY_INCLUDE_USAGE=true

# MCP
GITHUB_TOKEN=your_github_pat_here
YANBAN_MCP_GITHUB_ENABLED=false
YANBAN_MCP_GITHUB_COMMAND=cmd,/c,npx,-y,@modelcontextprotocol/server-github
YANBAN_MCP_GITHUB_ALLOWED_COMMANDS=cmd,npx,node
YANBAN_MCP_FILESYSTEM_ENABLED=false
YANBAN_MCP_FILESYSTEM_COMMAND=cmd,/c,npx,-y,@modelcontextprotocol/server-filesystem
YANBAN_MCP_FILESYSTEM_ALLOWED_COMMANDS=cmd,npx,node

# Security
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Production HTTP port exposed by docker-compose.prod.yml.
# Visit http://SERVER_IP:18080 when no domain is configured.
APP_HTTP_PORT=18080

# Public demo account. Keep disabled locally unless you want to test the shared demo flow.
DEMO_ENABLED=false
DEMO_USERNAME=demo
DEMO_RESET_CRON=0 30 3 * * *
DEMO_CANONICAL_URL=http://yanban.online:18080/demo
DEMO_MAX_UPLOAD_BYTES=3145728
DEMO_MAX_UPLOADS_PER_RESET=5
DEMO_MAX_CHAT_MESSAGES_PER_HOUR=60
DEMO_MAX_PAPER_TASKS_PER_RESET=2

# Invite codes (comma-separated, each max 5 uses by default)
INVITE_CODES=replace_with_invite_code_1,replace_with_invite_code_2

# Infrastructure defaults
MYSQL_ROOT_PASSWORD=yanban_root_password
MYSQL_DATABASE=yanban_agent
MYSQL_USER=yanban
MYSQL_PASSWORD=yanban_password
REDIS_PASSWORD=yanban_redis_password
MINIO_ROOT_USER=yanbanminio
MINIO_ROOT_PASSWORD=yanban_minio_password
MINIO_BUCKET=yanban-agent
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
YANBAN_ES_ENDPOINT=http://localhost:9200
YANBAN_ES_INDEX=yanban-kb-chunks-v1
YANBAN_ES_VECTOR_DIMS=1024
YANBAN_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
YANBAN_EMBEDDING_MODEL=text-embedding-v4
YANBAN_MINIO_ENDPOINT=http://localhost:9000
YANBAN_MINIO_BUCKET=yanban-agent
YANBAN_MINIO_SECURE=false
